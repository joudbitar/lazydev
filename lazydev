#!/usr/bin/env bash
# lazydev — CLI for the on-demand local dev-server proxy.
#
# Talks to the lazydev daemon's control API on :4000 (Host: lazydev.localhost).
# Zero hard dependencies beyond bash + curl + node + standard macOS tools.
# JSON is parsed/formatted with `node -e` (jq is NOT assumed to be present).

set -euo pipefail

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------

DAEMON_HOST="lazydev.localhost"
# Resolve this script's real directory, following the PATH symlink, so the CLI
# finds its sibling scan.mjs / projects.json / logs wherever the project lives.
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
CONFIG_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
SCAN_SCRIPT="${CONFIG_DIR}/scan.mjs"
RENDER_SCRIPT="${CONFIG_DIR}/bin/render-unit.mjs"
NODE="$(command -v node || echo node)"

# Platform: 'darwin' | 'linux' | 'other', via the same pure decision the
# installer uses (lib/service.mjs). Service control (restart/stop/install/
# uninstall) branches on this: launchctl on macOS, systemctl --user on Linux.
PLATFORM="$("$NODE" "$RENDER_SCRIPT" detect "$(uname -s)" 2>/dev/null || echo other)"

# Resolve the state directory the SAME way the installer and `npx lazydev` do:
# LAZYDEV_STATE_DIR wins, else the XDG state home (~/.local/state/lazydev). That
# is where the installed daemon keeps the registry, logs, and control token. If
# no registry is there yet, fall back to the legacy next-to-script layout, so the
# CLI still finds a daemon started bare from a checkout (state next to the code).
STATE_DIR="$("$NODE" -e '
  import(process.argv[1]).then(({ resolveStateDir }) => {
    const os = require("os");
    process.stdout.write(resolveStateDir({ env: process.env, home: os.homedir(), scriptDir: "", preferXdg: true }));
  }).catch(() => {});
' "${CONFIG_DIR}/lib/state.mjs" 2>/dev/null)"
if [ -z "$STATE_DIR" ] || { [ ! -f "${STATE_DIR}/projects.json" ] && [ -f "${CONFIG_DIR}/projects.json" ]; }; then
  STATE_DIR="${CONFIG_DIR}"
fi
LOG_DIR="${STATE_DIR}/logs"
DAEMON_LOG="${LOG_DIR}/daemon.log"
PROJECTS_JSON="${STATE_DIR}/projects.json"

PLIST_LABEL="com.lazydev.proxy"
PLIST_PATH="${HOME}/Library/LaunchAgents/${PLIST_LABEL}.plist"

# The control plane answers on the SAME port the daemon serves the front door on.
# The persistent install pins that to :80 (LAZYDEV_PORT); a bare or fallback run
# lands on the registry's top-level port. Read the registry's port, defaulting to
# 80 (the front-door port) so the CLI follows whatever the daemon actually serves.
DAEMON_PORT=80
if [ -f "$PROJECTS_JSON" ]; then
  _port="$("$NODE" -e 'try{const p=JSON.parse(require("fs").readFileSync(process.argv[1],"utf8")).port;if(Number.isFinite(p))process.stdout.write(String(p))}catch{}' "$PROJECTS_JSON" 2>/dev/null)"
  [ -n "$_port" ] && DAEMON_PORT="$_port"
fi
# Daemon binds loopback (127.0.0.1). Hit it by IP, not `localhost`, so we don't
# eat an IPv6-first (::1) resolution stall on machines where that resolves first.
BASE_URL="http://127.0.0.1:${DAEMON_PORT}"

# Capability token for the control plane. The daemon writes it (mode 0600) next
# to projects.json in the state dir at boot; we read it and send it on mutating
# control requests. tr strips the trailing newline the daemon writes.
CONTROL_TOKEN_FILE="${STATE_DIR}/control-token"
LAZYDEV_TOKEN=""
if [ -f "$CONTROL_TOKEN_FILE" ]; then
  LAZYDEV_TOKEN="$(tr -d '\r\n' < "$CONTROL_TOKEN_FILE" 2>/dev/null || true)"
fi

# ---------------------------------------------------------------------------
# Colors (TTY only — no escape codes when piped/redirected)
# ---------------------------------------------------------------------------

if [[ -t 1 ]]; then
  C_RESET=$'\033[0m'
  C_DIM=$'\033[2m'
  C_BOLD=$'\033[1m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_RED=$'\033[31m'
  C_CYAN=$'\033[36m'
else
  C_RESET="" C_DIM="" C_BOLD="" C_GREEN="" C_YELLOW="" C_RED="" C_CYAN=""
fi

# Node falls over without a real node binary; degrade to plain `node` on PATH.
if [[ ! -x "$NODE" ]]; then
  NODE="$(command -v node || true)"
fi

# ---------------------------------------------------------------------------
# Small helpers
# ---------------------------------------------------------------------------

err()  { printf '%s\n' "$*" >&2; }
die()  { err "${C_RED}lazydev:${C_RESET} $*"; exit 1; }

# curl against the control API. Args: METHOD PATH. Echoes body; returns curl's exit.
# Sends the capability token so mutating POSTs (up/stop/reload) are authorized.
# The CLI sends no Origin header (curl doesn't), so the daemon's same-origin
# check passes and the token alone authorizes the request.
api() {
  local method="$1" path="$2"
  local hdr=()
  [ -n "$LAZYDEV_TOKEN" ] && hdr=(-H "X-Lazydev-Token: ${LAZYDEV_TOKEN}")
  curl -fsS -m 10 -X "$method" -H "Host: ${DAEMON_HOST}" "${hdr[@]}" "${BASE_URL}${path}"
}

# True if the daemon answers on :4000.
daemon_up() {
  curl -fsS -m 3 -H "Host: ${DAEMON_HOST}" "${BASE_URL}/__lazydev/status" >/dev/null 2>&1
}

# True if something is listening on the given TCP port (localhost).
port_listening() {
  local p="$1"
  # `lsof -i` is the most reliable on macOS; fall back to nc.
  if command -v lsof >/dev/null 2>&1; then
    lsof -nP -iTCP:"$p" -sTCP:LISTEN >/dev/null 2>&1
  else
    nc -z -w1 127.0.0.1 "$p" >/dev/null 2>&1
  fi
}

require_host_arg() {
  [[ $# -ge 1 && -n "${1:-}" ]] || die "this command needs a <host>. Try: lazydev help"
}

daemon_down_message() {
  err "${C_RED}lazydev daemon is not reachable on :${DAEMON_PORT}.${C_RESET}"
  err "It may be asleep, crashed, or not installed yet."
  err "Try:  ${C_BOLD}lazydev restart${C_RESET}   (then check ${C_BOLD}lazydev status${C_RESET})"
}

# ---------------------------------------------------------------------------
# ls / (default) — the status table
# ---------------------------------------------------------------------------

cmd_ls() {
  local json
  if ! json="$(api GET /__lazydev/status 2>/dev/null)"; then
    daemon_down_message
    exit 1
  fi

  STATUS_JSON="$json" \
  C_RESET="$C_RESET" C_DIM="$C_DIM" C_BOLD="$C_BOLD" \
  C_GREEN="$C_GREEN" C_YELLOW="$C_YELLOW" C_CYAN="$C_CYAN" C_RED="$C_RED" \
  "$NODE" -e '
  (function () {
    const raw = process.env.STATUS_JSON || "{}";
    const C = {
      reset: process.env.C_RESET || "",
      dim:   process.env.C_DIM || "",
      bold:  process.env.C_BOLD || "",
      green: process.env.C_GREEN || "",
      yellow:process.env.C_YELLOW || "",
      cyan:  process.env.C_CYAN || "",
      red:   process.env.C_RED || "",
    };
    let s;
    try { s = JSON.parse(raw); } catch (e) {
      console.error("lazydev: could not parse status JSON from daemon");
      process.exit(1);
    }

    const projects = Array.isArray(s.projects) ? s.projects : [];

    // Humanize a duration in ms -> "4m", "2h", "3d", "12s", or "—".
    function humanize(ms) {
      if (ms == null || !isFinite(ms) || ms < 0) return "—";
      const sec = Math.floor(ms / 1000);
      if (sec < 60) return sec + "s";
      const min = Math.floor(sec / 60);
      if (min < 60) return min + "m";
      const hr = Math.floor(min / 60);
      if (hr < 24) return hr + "h";
      const d = Math.floor(hr / 24);
      return d + "d";
    }

    // Header line: uptime + idle timeout.
    const uptime = humanize(s.uptimeMs);
    const idleTimeout = humanize(s.idleTimeoutMs);
    console.log(
      C.bold + "lazydev" + C.reset +
      C.dim + "  daemon up " + C.reset + uptime +
      C.dim + "  ·  sleeps idle projects after " + C.reset + idleTimeout
    );
    console.log("");

    if (projects.length === 0) {
      console.log(C.dim + "No projects registered. Run `lazydev scan` to discover them." + C.reset);
      return;
    }

    // Build display rows (plain strings) plus a colorizer for STATE.
    const rows = projects.map((p) => {
      const host  = String(p.host ?? "");
      const url   = "http://" + host + ".localhost";
      const state = String(p.state ?? "stopped");
      // Stopped is presented to the user as "sleeping".
      const stateLabel = state === "stopped" ? "sleeping" : state;
      const idle  = state === "running" ? humanize(p.idleForMs) : "—";
      const conn  = (p.connCount ?? 0).toString();
      const port  = (p.port ?? "").toString();
      const enabled = p.enabled !== false;
      return { host, url, state, stateLabel, idle, conn, port, enabled };
    });

    const headers = { host: "HOST", url: "URL", state: "STATE", idle: "IDLE", conn: "CONN", port: "PORT" };

    // Column widths = max of header and all cell values (uncolored lengths).
    function w(key, label) {
      return rows.reduce((m, r) => Math.max(m, String(r[key === "state" ? "stateLabel" : key]).length), label.length);
    }
    const wHost  = w("host",  headers.host);
    const wUrl   = w("url",   headers.url);
    const wState = w("state", headers.state);
    const wIdle  = w("idle",  headers.idle);
    const wConn  = w("conn",  headers.conn);

    function pad(str, width) {
      str = String(str);
      const gap = width - str.length;
      return gap > 0 ? str + " ".repeat(gap) : str;
    }

    function colorState(r) {
      const padded = pad(r.stateLabel, wState);
      if (!r.enabled) return C.dim + padded + C.reset;
      if (r.state === "running")  return C.green + padded + C.reset;
      if (r.state === "starting") return C.yellow + padded + C.reset;
      if (r.state === "conflict") return C.red + padded + C.reset;
      // stopped / sleeping
      return C.dim + padded + C.reset;
    }

    // Header row (dim).
    console.log(
      C.dim +
      pad(headers.host, wHost) + "  " +
      pad(headers.url, wUrl) + "  " +
      pad(headers.state, wState) + "  " +
      pad(headers.idle, wIdle) + "  " +
      pad(headers.conn, wConn) + "  " +
      headers.port +
      C.reset
    );

    for (const r of rows) {
      const hostCell = r.enabled ? pad(r.host, wHost) : (C.dim + pad(r.host, wHost) + C.reset);
      const urlCell  = C.cyan + pad(r.url, wUrl) + C.reset;
      console.log(
        hostCell + "  " +
        urlCell + "  " +
        colorState(r) + "  " +
        pad(r.idle, wIdle) + "  " +
        pad(r.conn, wConn) + "  " +
        r.port
      );
    }
  })();
  '
}

# ---------------------------------------------------------------------------
# open <host> — wake the project and launch the browser
# ---------------------------------------------------------------------------

cmd_open() {
  require_host_arg "$@"
  local host="$1"
  local url="http://${host}.localhost"

  if ! daemon_up; then
    daemon_down_message
    exit 1
  fi

  printf '%sWaking%s %s ...\n' "$C_DIM" "$C_RESET" "$host"
  local resp
  if ! resp="$(api POST "/__lazydev/up/${host}" 2>/dev/null)"; then
    die "could not wake '${host}'. Is it a registered project? (lazydev ls)"
  fi

  # Surface a daemon-reported failure reason if present.
  local ok
  ok="$(RESP="$resp" "$NODE" -e 'try{const o=JSON.parse(process.env.RESP||"{}");process.stdout.write(o.ok?"yes":(o.reason||"no"))}catch(e){process.stdout.write("yes")}')"
  if [[ "$ok" != "yes" ]]; then
    die "daemon could not start '${host}': ${ok}"
  fi

  printf '%s\n' "$url"
  open "$url"
}

# ---------------------------------------------------------------------------
# sleep <host> — put a project to sleep
# ---------------------------------------------------------------------------

cmd_sleep() {
  require_host_arg "$@"
  local host="$1"

  if ! daemon_up; then
    daemon_down_message
    exit 1
  fi

  if ! api POST "/__lazydev/stop/${host}" >/dev/null 2>&1; then
    die "could not reach the daemon to sleep '${host}'."
  fi
  printf '%s%s%s is now %ssleeping%s.\n' "$C_BOLD" "$host" "$C_RESET" "$C_DIM" "$C_RESET"
}

# ---------------------------------------------------------------------------
# logs <host> [-f] — tail a project's log
# ---------------------------------------------------------------------------

cmd_logs() {
  require_host_arg "$@"
  local host="$1"; shift || true
  local follow=0
  [[ "${1:-}" == "-f" || "${1:-}" == "--follow" ]] && follow=1

  local log="${LOG_DIR}/${host}.log"
  if [[ ! -f "$log" ]]; then
    err "${C_DIM}No log for '${host}' yet — it hasn't started.${C_RESET}"
    err "Wake it with:  ${C_BOLD}lazydev open ${host}${C_RESET}"
    exit 1
  fi

  if [[ "$follow" -eq 1 ]]; then
    tail -f "$log"
  else
    tail -n 200 "$log"
  fi
}

# ---------------------------------------------------------------------------
# daemon-logs [-f] — tail the daemon log
# ---------------------------------------------------------------------------

cmd_daemon_logs() {
  local follow=0
  [[ "${1:-}" == "-f" || "${1:-}" == "--follow" ]] && follow=1

  if [[ ! -f "$DAEMON_LOG" ]]; then
    die "no daemon log at ${DAEMON_LOG} (daemon may not have started yet)."
  fi

  if [[ "$follow" -eq 1 ]]; then
    tail -f "$DAEMON_LOG"
  else
    tail -n 200 "$DAEMON_LOG"
  fi
}

# ---------------------------------------------------------------------------
# scan — rescan ~ for projects, reload, show table
# ---------------------------------------------------------------------------

cmd_scan() {
  [[ -f "$SCAN_SCRIPT" ]] || die "scanner not found at ${SCAN_SCRIPT}"
  printf '%sScanning for projects ...%s\n' "$C_DIM" "$C_RESET"
  "$NODE" "$SCAN_SCRIPT"

  if daemon_up; then
    if api POST /__lazydev/reload >/dev/null 2>&1; then
      printf '%sRegistry reloaded.%s\n\n' "$C_DIM" "$C_RESET"
    else
      err "${C_YELLOW}Warning:${C_RESET} scan wrote projects.json but the daemon reload failed."
    fi
    cmd_ls
  else
    printf '%sRegistry updated. Daemon is down — start it with `lazydev restart`.%s\n' "$C_DIM" "$C_RESET"
  fi
}

# ---------------------------------------------------------------------------
# Service control — one place, branches on platform (launchctl vs systemctl)
# ---------------------------------------------------------------------------

# Restart the daemon's user service. Returns non-zero if no service is installed.
service_restart() {
  if [[ "$PLATFORM" == "darwin" ]]; then
    local uid; uid="$(id -u)"
    # Preferred: kickstart -k (kill + relaunch) the gui-domain service.
    if launchctl kickstart -k "gui/${uid}/${PLIST_LABEL}" >/dev/null 2>&1; then
      return 0
    fi
    # Fallback: unload + load -w the plist.
    if [[ -f "$PLIST_PATH" ]]; then
      launchctl unload "$PLIST_PATH" >/dev/null 2>&1 || true
      launchctl load -w "$PLIST_PATH" >/dev/null 2>&1 || return 1
      return 0
    fi
    return 1
  elif [[ "$PLATFORM" == "linux" ]]; then
    command -v systemctl >/dev/null 2>&1 || return 1
    systemctl --user restart lazydev.service >/dev/null 2>&1
    return $?
  fi
  return 1
}

# Stop the daemon's user service (leaves it installed / enabled).
service_stop_daemon() {
  if [[ "$PLATFORM" == "darwin" ]]; then
    local uid; uid="$(id -u)"
    launchctl bootout "gui/${uid}/${PLIST_LABEL}" >/dev/null 2>&1 && return 0
    [[ -f "$PLIST_PATH" ]] && launchctl unload "$PLIST_PATH" >/dev/null 2>&1
    return $?
  elif [[ "$PLATFORM" == "linux" ]]; then
    command -v systemctl >/dev/null 2>&1 || return 1
    systemctl --user stop lazydev.service >/dev/null 2>&1
    return $?
  fi
  return 1
}

# ---------------------------------------------------------------------------
# restart — bounce the daemon's user service and wait for the front door
# ---------------------------------------------------------------------------

cmd_restart() {
  printf '%sRestarting the lazydev daemon ...%s\n' "$C_DIM" "$C_RESET"

  if ! service_restart; then
    if [[ "$PLATFORM" == "linux" ]]; then
      die "no lazydev.service found; run the installer (install.sh) first."
    else
      die "no LaunchAgent at ${PLIST_PATH}; run the installer (install.sh) first."
    fi
  fi

  # Wait up to ~15s for the control port to answer.
  local i
  for i in $(seq 1 30); do
    if daemon_up; then
      printf '%sDaemon is back up.%s\n\n' "$C_GREEN" "$C_RESET"
      cmd_ls
      return 0
    fi
    sleep 0.5
  done

  die "daemon did not come back on :${DAEMON_PORT} within 15s. Check: lazydev daemon-logs"
}

# ---------------------------------------------------------------------------
# install / uninstall — run the persistent-daemon (un)installer for this project
# ---------------------------------------------------------------------------

cmd_install() {
  local script="${CONFIG_DIR}/install.sh"
  [[ -f "$script" ]] || die "installer not found at ${script}"
  exec bash "$script" "$@"
}

cmd_uninstall() {
  local script="${CONFIG_DIR}/uninstall.sh"
  [[ -f "$script" ]] || die "uninstaller not found at ${script}"
  exec bash "$script" "$@"
}

# ---------------------------------------------------------------------------
# status — health for the daemon (which IS the front door) and its user service
# ---------------------------------------------------------------------------

# Report whether the user service is registered with the init system. Echoes a
# short state string; no daemon calls, just the launchd/systemd view.
service_state() {
  if [[ "$PLATFORM" == "darwin" ]]; then
    local uid; uid="$(id -u)"
    if launchctl print "gui/${uid}/${PLIST_LABEL}" >/dev/null 2>&1; then
      printf '%sloaded (launchd)%s' "$C_GREEN" "$C_RESET"
    elif [[ -f "$PLIST_PATH" ]]; then
      printf '%sinstalled, not loaded%s' "$C_YELLOW" "$C_RESET"
    else
      printf '%snot installed%s' "$C_DIM" "$C_RESET"
    fi
  elif [[ "$PLATFORM" == "linux" ]]; then
    if command -v systemctl >/dev/null 2>&1 && systemctl --user is-active lazydev.service >/dev/null 2>&1; then
      printf '%sactive (systemd)%s' "$C_GREEN" "$C_RESET"
    elif command -v systemctl >/dev/null 2>&1 && systemctl --user list-unit-files lazydev.service >/dev/null 2>&1 \
      && systemctl --user cat lazydev.service >/dev/null 2>&1; then
      printf '%sinstalled, not active%s' "$C_YELLOW" "$C_RESET"
    else
      printf '%snot installed%s' "$C_DIM" "$C_RESET"
    fi
  else
    printf '%sn/a%s' "$C_DIM" "$C_RESET"
  fi
}

cmd_status() {
  local daemon_state

  # The daemon serves the front door directly (no Caddy). The control API and the
  # front door are the same listener on the same port, so one probe covers both.
  if daemon_up; then
    daemon_state="${C_GREEN}OK${C_RESET}"
  elif port_listening "$DAEMON_PORT"; then
    # Something's on the port but not answering the control API.
    daemon_state="${C_YELLOW}LISTENING (not responding)${C_RESET}"
  else
    daemon_state="${C_RED}DOWN${C_RESET}"
  fi

  printf 'daemon / front door  (:%s)  %b\n' "$DAEMON_PORT" "$daemon_state"
  printf 'user service               %b\n' "$(service_state)"
}

# ---------------------------------------------------------------------------
# dash — open the daemon's HTML dashboard
# ---------------------------------------------------------------------------

cmd_dash() {
  local url="http://${DAEMON_HOST}"
  printf '%s\n' "$url"
  open "$url"
}

# ---------------------------------------------------------------------------
# help
# ---------------------------------------------------------------------------

cmd_help() {
  cat <<EOF
${C_BOLD}lazydev${C_RESET} — on-demand local dev-server proxy

Every project is reachable at ${C_CYAN}http://<host>.localhost${C_RESET}. The dev server
starts on the first request and sleeps after 30 minutes of inactivity.

${C_BOLD}USAGE${C_RESET}
  lazydev [ls]                 List projects, states, idle time, ports
  lazydev open <host>          Wake a project and open it in the browser
  lazydev sleep <host>         Put a project to sleep now
  lazydev logs <host> [-f]     Tail a project's log (-f to follow)
  lazydev daemon-logs [-f]     Tail the daemon's log (-f to follow)
  lazydev scan                 Rescan ~ for projects, reload registry, list
  lazydev restart              Restart the daemon, wait for it, then list
  lazydev status               Health: daemon (front door) + user service
  lazydev install              Install the persistent background daemon
  lazydev uninstall            Remove the persistent background daemon
  lazydev dash                 Open the daemon's HTML dashboard
  lazydev help                 Show this help

${C_BOLD}EXAMPLES${C_RESET}
  lazydev                      # the status table
  lazydev open tradepulse      # http://tradepulse.localhost in your browser
  lazydev logs tradepulse -f   # follow that project's dev-server output
  lazydev sleep traypal        # free its port now

Registry: ${C_DIM}${PROJECTS_JSON}${C_RESET}
Logs:     ${C_DIM}${LOG_DIR}/${C_RESET}
EOF
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------

main() {
  local cmd="${1:-ls}"
  [[ $# -gt 0 ]] && shift || true

  case "$cmd" in
    ls|list|"")        cmd_ls "$@" ;;
    open)              cmd_open "$@" ;;
    sleep|stop)        cmd_sleep "$@" ;;
    logs)              cmd_logs "$@" ;;
    daemon-logs)       cmd_daemon_logs "$@" ;;
    scan)              cmd_scan "$@" ;;
    restart)           cmd_restart "$@" ;;
    status)            cmd_status "$@" ;;
    install)           cmd_install "$@" ;;
    uninstall)         cmd_uninstall "$@" ;;
    dash)              cmd_dash "$@" ;;
    help|-h|--help)    cmd_help ;;
    *)
      err "${C_RED}lazydev: unknown command '${cmd}'${C_RESET}"
      err ""
      cmd_help >&2
      exit 1
      ;;
  esac
}

main "$@"
